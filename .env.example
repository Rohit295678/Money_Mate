# Postgres connection string.
# Local dev: install Postgres locally OR use a free Neon dev branch.
# Vercel:    set this in Project Settings > Environment Variables.
#
# For Neon, you typically get TWO URLs:
#   - Pooled (use as DATABASE_URL):   ...?sslmode=require&channel_binding=require  (uses pgbouncer, append &pgbouncer=true&connection_limit=1)
#   - Direct (use as DIRECT_URL):     unpooled, used by `prisma migrate`
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require&pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# NextAuth
# Generate a fresh value with:  openssl rand -base64 32
NEXTAUTH_SECRET="REPLACE_WITH_RANDOM_32_BYTES"

# Local: http://localhost:3000
# Vercel: https://your-app.vercel.app  (Vercel sets this automatically via NEXTAUTH_URL or via VERCEL_URL — set it explicitly to your prod URL)
NEXTAUTH_URL="http://localhost:3000"
